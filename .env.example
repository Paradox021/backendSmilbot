# ============================
# Smilbot Backend - Environment
# ============================

# Server
PORT=3000
URL_DB=mongodb://localhost:27017/smilbot

# Image provider: 'local' | 'cloudinary' | 'supabase'
IMAGE_PROVIDER=local

# ---- Local provider ----
IMAGE_HOST=http://localhost:3000

# ---- Cloudinary (required if IMAGE_PROVIDER=cloudinary) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=smilbot

# ---- Supabase Storage (required if IMAGE_PROVIDER=supabase) ----
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=smilbot-images
